# ============================================================
# Cygnal Production Environment Configuration Template
# Copy this file to .env and fill in all required values.
# NEVER commit .env to version control.
# ============================================================

# --- Database -------------------------------------------------
POSTGRES_USER=cygnal_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=cygnal_prod

# --- JWT Authentication ----------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=CHANGE_ME_minimum_64_character_random_hex_string
JWT_EXPIRY=3d

# --- Webhook Authentication -----------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
CYGNAL_WEBHOOK_SECRET=CHANGE_ME_strong_random_webhook_secret

# --- Redis / Celery -------------------------------------------
REDIS_URL=redis://redis:6379/0
USE_CELERY=true

# --- Admin Seed Account (optional) ---------------------------
# Only used on first boot if users table is empty.
CYGNAL_ADMIN_USERNAME=admin
CYGNAL_ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# --- CORS -----------------------------------------------------
CORS_ORIGINS=http://localhost:3000
