JWT_SECRET=your_very_strong_secret_key_here
JWT_EXPIRY=3d

# External API keys (optional — scanners degrade gracefully without them)
ABUSEIPDB_API_KEY=your_key
VIRUSTOTAL_API_KEY=your_key
HYBRID_API_KEY=your_key

# Frontend proxy target (set in Vercel/production; defaults to localhost:5000 locally)
CYGNAL_API_URL=http://localhost:5000
