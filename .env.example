# ============ CRITICAL: SECURITY CONFIGURATION ============
# These environment variables are REQUIRED for secure operation.
# Never commit production secrets to version control.

# JWT Secret Key for signing authentication tokens
# REQUIRED: Must be a strong, random string (minimum 32 characters)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your_very_strong_secret_key_here

# JWT Token Expiry (format: "3d", "24h", etc.)
JWT_EXPIRY=3d

# ============ ADMIN ACCOUNT SEEDING (Optional) ============
# If provided, the application will seed a default admin user on first startup.
# SECURITY: Only use for initial setup. Remove after first login.
CYGNAL_ADMIN_USERNAME=
CYGNAL_ADMIN_PASSWORD=

# ============ DATABASE CONFIGURATION ============
# PostgreSQL connection string (for production)
# If not set, SQLite will be used (development only)
DATABASE_URL=

# ============ REDIS CONFIGURATION ============
# Redis broker URL for Celery background workers
REDIS_URL=redis://localhost:6379/0

# ============ CORS CONFIGURATION ============
# Allowed origins for CORS requests (comma-separated)
# SECURITY: Do NOT use "*" in production. Specify exact origins.
# Example: http://localhost:3000,https://app.example.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============ DEPLOYMENT CONFIGURATION ============
# Set to "true" only for local development (NEVER in production)
FLASK_DEBUG=false

# Frontend API URL (used by frontend app)
BACKEND_URL=http://localhost:5000

# ============ EXTERNAL API KEYS (Optional) ============
# These scanners degrade gracefully without API keys
# Only set if you have accounts with these services
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=
HYBRID_API_KEY=
